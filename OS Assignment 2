#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main() {

    int fd_req, fd_res;
    int a, b, result;
    char op;

    // Open pipes
    fd_req = open("req_pipe", O_WRONLY);
    fd_res = open("res_pipe", O_RDONLY);

    // Get input from user
    printf("Enter first number: ");
    scanf("%d", &a);

    printf("Enter operator (+ - * /): ");
    scanf(" %c", &op);

    printf("Enter second number: ");
    scanf("%d", &b);

    // Send request
    write(fd_req, &a, sizeof(a));
    write(fd_req, &b, sizeof(b));
    write(fd_req, &op, sizeof(op));

    // Receive result
    read(fd_res, &result, sizeof(result));

    printf("Result from server = %d\n", result);

    close(fd_req);
    close(fd_res);

    return 0;






server.c
#include <stdio.h>
#include <fcntl.h>
#include <sys/stat.h>
#include <unistd.h>

int main() {

    int fd_req, fd_res;
    int a, b, result;
    char op;

    // Create FIFOs
    mkfifo("req_pipe", 0666);
    mkfifo("res_pipe", 0666);

    printf("Server started... waiting for client\n");

    // Open pipes
    fd_req = open("req_pipe", O_RDONLY);
    fd_res = open("res_pipe", O_WRONLY);

    // Read request from client
    read(fd_req, &a, sizeof(a));
    read(fd_req, &b, sizeof(b));
    read(fd_req, &op, sizeof(op));

    // Perform operation
    if(op == '+')
        result = a + b;
    else if(op == '-')
        result = a - b;
    else if(op == '*')
        result = a * b;
    else if(op == '/')
        result = a / b;
    else
        result = 0;

    // Send result to client
    write(fd_res, &result, sizeof(result));

    printf("Processed: %d %c %d = %d\n", a, op, b, result);

    close(fd_req);
    close(fd_res);

    return 0;
}
}
